---
const instanceId = `feedback-chat-${Math.random().toString(36).slice(2, 9)}`;

const {
  managerName = "You",
  learnerName = "Sam",
  managerAvatar = "",
  learnerAvatar = "",
} = Astro.props;

const getInitials = (name: string) =>
  name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();

const managerInitials = getInitials(managerName);
const learnerInitials = getInitials(learnerName);
---

<section id={instanceId} class="mx-auto w-full max-w-6xl">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_320px]">
    <div class="card border border-base-300 bg-base-100 shadow-x  border-1 border-gray-400">
      <div class="card-body gap-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-black">
              Branching scenario
            </p>
            <h2 class="card-title text-3xl">Giving Feedback: Chat Scenario</h2>
            <p class="max-w-2xl text-base-content/70">
              Practice choosing feedback that is specific, respectful, and actionable.
            </p>
          </div>

          <div class="rounded-2xl border border-gray-500/20 bg-gray-100 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-wide text-black">
              Quality score
            </p>
            <p class="text-2xl font-bold" data-score>0%</p>
          </div>
        </div>

        <!-- Character row -->
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="flex items-center gap-3 rounded-2xl border border-base-300 bg-base-100 p-4 border-1 border-gray-400">
            <div class="avatar">
              <div class="w-14 rounded-full ring ring-black ring-offset-2 ring-offset-base-100 overflow-hidden bg-black text-black-content flex items-center justify-center font-bold">
                {
                  managerAvatar ? (
                    <img src={managerAvatar} alt={managerName} class="h-full w-full object-cover" />
                  ) : (
                    <span>{managerInitials}</span>
                  )
                }
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wide text-base-content/50">Feedback giver</p>
              <p class="font-semibold">{managerName}</p>
              <p class="text-sm text-base-content/70">Chooses what to say next</p>
            </div>
          </div>

          <div class="flex items-center gap-3 rounded-2xl border border-base-300 bg-base-100 p-4 border-1 border-gray-400 border-1 border-gray-400">
            <div class="avatar">
              <div class="w-14 rounded-full ring ring-black ring-offset-2 ring-offset-base-100 overflow-hidden bg-black text-secondary-content flex items-center justify-center font-bold">
                {
                  learnerAvatar ? (
                    <img src={learnerAvatar} alt={learnerName} class="h-full w-full object-cover" />
                  ) : (
                    <span>{learnerInitials}</span>
                  )
                }
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wide text-base-content/50">Team member</p>
              <p class="font-semibold">{learnerName}</p>
              <p class="text-sm text-base-content/70">Responds during the scenario</p>
            </div>
          </div>
        </div>

        <!-- Stage map -->
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <div data-step="1" class="rounded-2xl border border-base-300 bg-base-200 p-3 transition">
            <p class="text-xs uppercase tracking-wide opacity-60">Step 1</p>
            <p class="font-semibold">Open well</p>
          </div>
          <div data-step="2" class="rounded-2xl border border-base-300 bg-base-200 p-3 transition">
            <p class="text-xs uppercase tracking-wide opacity-60">Step 2</p>
            <p class="font-semibold">Clarify behaviour</p>
          </div>
          <div data-step="3" class="rounded-2xl border border-base-300 bg-base-200 p-3 transition">
            <p class="text-xs uppercase tracking-wide opacity-60">Step 3</p>
            <p class="font-semibold">Explain impact</p>
          </div>
          <div data-step="4" class="rounded-2xl border border-base-300 bg-base-200 p-3 transition">
            <p class="text-xs uppercase tracking-wide opacity-60">Step 4</p>
            <p class="font-semibold">Agree next step</p>
          </div>
        </div>

        <progress class="progress progress-black w-full" max="4" value="1" data-progress></progress>

        <!-- Chat area -->
        <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
          <div class="mb-4 flex flex-wrap items-center gap-3">
            <span class="badge badge-outline" data-stage-label>Step 1 of 4</span>
            <span class="text-sm text-base-content/60" data-coach-focus></span>
          </div>

          <div class="max-h-[32rem] space-y-4 overflow-y-auto pr-1" data-thread></div>

          <div class="mt-4 rounded-xl border border-base-300 bg-base-100 px-4 py-3">
            <p class="text-sm font-semibold text-base-content/60">Your next move</p>
            <p class="mt-1 text-base-content/80" data-prompt></p>
          </div>
        </div>

        <!-- Options -->
        <div class="grid gap-3" data-options></div>

        <!-- Choice feedback -->
        <div class="hidden rounded-2xl border border-black/20 bg-black10 p-5" data-feedback-wrap>
          <div class="mb-3 flex flex-wrap items-center gap-3">
            <span class="badge badge-outline" data-feedback-strength>Choice feedback</span>
            <p class="font-semibold" data-feedback-title></p>
          </div>

          <p class="mb-4 text-base-content/80" data-feedback-text></p>

          <button type="button" class="btn btn-black" data-continue>
            Continue
          </button>
        </div>

        <!-- Ending -->
        <div class="hidden rounded-2xl border border-success/20 bg-success/10 p-5" data-end-wrap>
          <div class="mb-3 flex flex-wrap items-center gap-3">
            <h4 class="text-2xl font-bold" data-end-title></h4>
            <span class="badge badge-outline" data-rating></span>
          </div>

          <p class="mb-4 whitespace-pre-line text-base-content/80" data-end-text></p>

          <div class="mb-4 grid gap-4 md:grid-cols-2">
            <div class="rounded-xl border border-base-300 bg-base-100 p-4">
              <p class="mb-2 font-semibold">Your final score</p>
              <p class="text-3xl font-bold" data-final-score>0%</p>
              <p class="mt-2 text-sm text-base-content/60">
                Based on how helpful your choices were across the scenario.
              </p>
            </div>

            <div class="rounded-xl border border-base-300 bg-base-100 p-4">
              <p class="mb-2 font-semibold">Model response</p>
              <p class="text-sm leading-6 text-base-content/80">
                “In today’s meeting, you interrupted Priya twice while she was explaining her
                update. It made it harder for others to finish their ideas. In future meetings,
                let people finish before you jump in, and jot down your point if needed.”
              </p>
            </div>
          </div>

          <div class="rounded-xl border border-base-300 bg-base-100 p-4">
            <p class="mb-2 font-semibold">Why this works</p>
            <ul class="list-disc space-y-1 pl-5 text-sm text-base-content/80">
              <li>It describes observable behaviour, not personality.</li>
              <li>It explains the impact on others.</li>
              <li>It ends with a clear, realistic next step.</li>
            </ul>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          <button type="button" class="btn btn-outline" data-restart>
            Restart scenario
          </button>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="card border border-base-300 bg-base-100 shadow-lg border-1 border-gray-400">
        <div class="card-body">
          <h3 class="card-title text-lg">Your path</h3>
          <p class="text-sm text-base-content/60">
            Your choices appear here as you move through the chat.
          </p>

          <div class="mt-3 flex flex-wrap gap-2" data-path></div>
          <p class="text-sm text-base-content/50" data-path-empty>No decisions yet.</p>
        </div>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-lg border-1 border-gray-400 border-1 border-gray-400">
        <div class="card-body">
          <h3 class="card-title text-lg">Helpful feedback formula</h3>
          <div class="space-y-3 text-sm text-base-content/80">
            <div class="rounded-xl bg-base-200 p-3">
              <p class="font-semibold">1. Situation</p>
              <p>Name the moment or context.</p>
            </div>
            <div class="rounded-xl bg-base-200 p-3">
              <p class="font-semibold">2. Behaviour</p>
              <p>Describe what you observed.</p>
            </div>
            <div class="rounded-xl bg-base-200 p-3">
              <p class="font-semibold">3. Impact</p>
              <p>Explain the effect on others or the work.</p>
            </div>
            <div class="rounded-xl bg-base-200 p-3">
              <p class="font-semibold">4. Next step</p>
              <p>Suggest a clear improvement.</p>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<script
  define:vars={{
    instanceId,
    managerName,
    learnerName,
    managerAvatar,
    learnerAvatar,
    managerInitials,
    learnerInitials,
  }}
>
  const scenario = {
    start: {
      stage: 1,
      stageLabel: "Open the conversation",
      coachFocus: "Start with observable facts, not judgement.",
      prompt: "What do you say first?",
      messages: [
        {
          speaker: "narrator",
          text:
            "You are leading a weekly team check-in. Sam, a capable and enthusiastic team member, has started interrupting others during meetings.",
        },
        {
          speaker: "narrator",
          text:
            "After today's meeting, you decide to give feedback privately.",
        },
      ],
      options: [
        {
          label: "“You need to be more professional in meetings.”",
          choiceBubble: "You need to be more professional in meetings.",
          pathLabel: "Vague opener",
          points: 0,
          feedback:
            "This sounds judgemental and vague. Sam may feel criticised without understanding what needs to change.",
          next: "vague",
        },
        {
          label: "“In today’s meeting, you interrupted Priya twice while she was explaining her update.”",
          choiceBubble:
            "In today’s meeting, you interrupted Priya twice while she was explaining her update.",
          pathLabel: "Specific example",
          points: 2,
          feedback:
            "Strong start. This is specific, factual, and focused on observable behaviour.",
          next: "specific",
        },
        {
          label: "“You’re great to work with, but some people feel frustrated.”",
          choiceBubble:
            "You’re great to work with, but some people feel frustrated.",
          pathLabel: "Indirect opener",
          points: 1,
          feedback:
            "This is gentler, but still indirect. Sam may not know exactly what behaviour caused the issue.",
          next: "indirect",
        },
      ],
    },

    vague: {
      stage: 2,
      stageLabel: "Clarify the behaviour",
      coachFocus: "Replace labels with concrete examples.",
      prompt: "How do you respond now?",
      messages: [
        {
          speaker: "learner",
          text: "Professional? I thought I was just contributing.",
        },
      ],
      options: [
        {
          label: "Double down: “It’s just not a good look.”",
          choiceBubble: "It’s just not a good look.",
          pathLabel: "Double down",
          points: 0,
          feedback:
            "This increases defensiveness and still gives no useful detail.",
          ending: {
            title: "Outcome: Defensive and unclear",
            text:
              "The conversation becomes tense. Sam leaves feeling criticised rather than coached.\n\nBecause the feedback stayed vague, the behaviour is likely to continue.",
          },
        },
        {
          label: "Reset: “Let me be more specific about what I noticed.”",
          choiceBubble: "Let me be more specific about what I noticed.",
          pathLabel: "Recover with clarity",
          points: 2,
          feedback:
            "Good recovery. You are shifting from judgement to useful observation.",
          next: "specific_followup",
        },
      ],
    },

    indirect: {
      stage: 2,
      stageLabel: "Clarify the behaviour",
      coachFocus: "Helpful feedback becomes useful when it gets concrete.",
      prompt: "You have a chance to make your feedback more useful.",
      messages: [
        {
          speaker: "learner",
          text: "Okay… what exactly did I do?",
        },
      ],
      options: [
        {
          label: "“You interrupted Priya and David before they finished their points.”",
          choiceBubble: "You interrupted Priya and David before they finished their points.",
          pathLabel: "Clarified example",
          points: 2,
          feedback:
            "Much better. Now the feedback is concrete and easier to act on.",
          next: "specific_followup",
        },
        {
          label: "“I don’t want to get into details — just try to be more aware.”",
          choiceBubble: "I don’t want to get into details — just try to be more aware.",
          pathLabel: "Avoided details",
          points: 0,
          feedback:
            "This avoids discomfort, but it also avoids clarity. Sam still does not know what to change.",
          ending: {
            title: "Outcome: Polite but ineffective",
            text:
              "The conversation stays friendly, but the feedback is too unclear to drive improvement.\n\nSam may leave with good intentions, but without a useful next step.",
          },
        },
      ],
    },

    specific: {
      stage: 3,
      stageLabel: "Explain the impact",
      coachFocus: "Connect the behaviour to its effect on others.",
      prompt: "What do you say next?",
      messages: [
        {
          speaker: "learner",
          text: "I didn’t realise I was doing that.",
        },
      ],
      options: [
        {
          label: "Explain the impact: “It made it harder for others to finish their ideas.”",
          choiceBubble: "It made it harder for others to finish their ideas.",
          pathLabel: "Explained impact",
          points: 2,
          feedback:
            "Excellent. This connects the behaviour to its effect on the team.",
          next: "impact",
        },
        {
          label: "Make it personal: “You can come across as disrespectful.”",
          choiceBubble: "You can come across as disrespectful.",
          pathLabel: "Made it personal",
          points: 0,
          feedback:
            "This risks defensiveness because it shifts from behaviour to identity.",
          next: "personal",
        },
      ],
    },

    specific_followup: {
      stage: 3,
      stageLabel: "Explain the impact",
      coachFocus: "Once the behaviour is clear, explain why it matters.",
      prompt: "What should you add next?",
      messages: [
        {
          speaker: "learner",
          text: "Okay, I see what you mean.",
        },
      ],
      options: [
        {
          label: "Explain the impact on the meeting and the team.",
          choiceBubble:
            "When that happens, it makes it harder for other people to finish their ideas.",
          pathLabel: "Added impact",
          points: 2,
          feedback:
            "Yes. Helpful feedback often connects behaviour to impact.",
          next: "impact",
        },
        {
          label: "Move straight to a warning.",
          choiceBubble: "This can’t keep happening, and it may become a bigger issue.",
          pathLabel: "Jumped to warning",
          points: 0,
          feedback:
            "That jumps too quickly to consequences before supporting improvement.",
          next: "warning",
        },
      ],
    },

    personal: {
      stage: 3,
      stageLabel: "Explain the impact",
      coachFocus: "Refocus on effect, not intention or character.",
      prompt: "How do you steer the conversation back?",
      messages: [
        {
          speaker: "learner",
          text: "I wasn’t trying to be disrespectful.",
        },
      ],
      options: [
        {
          label: "Refocus: “I understand. I’m talking about the effect, not your intention.”",
          choiceBubble:
            "I understand. I’m talking about the effect, not your intention.",
          pathLabel: "Refocused on effect",
          points: 2,
          feedback:
            "Good recovery. You are bringing the conversation back to impact and behaviour.",
          next: "impact",
        },
        {
          label: "Press harder: “Well, that’s how you come across.”",
          choiceBubble: "Well, that’s how you come across.",
          pathLabel: "Escalated tone",
          points: 0,
          feedback:
            "This is likely to increase defensiveness and reduce learning.",
          ending: {
            title: "Outcome: Resistance increases",
            text:
              "Sam feels labelled rather than supported. The feedback conversation stalls.\n\nWhen feedback feels personal, people often focus on defending themselves instead of improving.",
          },
        },
      ],
    },

    warning: {
      stage: 4,
      stageLabel: "Agree a next step",
      coachFocus: "Coach before you escalate.",
      prompt: "What do you do now?",
      messages: [
        {
          speaker: "learner",
          text: "I didn’t realise it had become such a big issue.",
        },
      ],
      options: [
        {
          label: "Step back and describe the impact, then suggest a better approach.",
          choiceBubble:
            "Let me step back. When it happens, it cuts people off. Next time, let them finish before you jump in.",
          pathLabel: "Recovered from warning",
          points: 2,
          feedback:
            "Good correction. You are returning to a coaching approach.",
          next: "impact",
        },
        {
          label: "End the conversation there.",
          choiceBubble: "Alright, that’s all I wanted to say.",
          pathLabel: "Ended too soon",
          points: 0,
          feedback:
            "This leaves the feedback incomplete and less useful.",
          ending: {
            title: "Outcome: Incomplete coaching",
            text:
              "Sam knows there is a problem, but not clearly how to improve.\n\nThe feedback may create anxiety without creating learning.",
          },
        },
      ],
    },

    impact: {
      stage: 4,
      stageLabel: "Agree a next step",
      coachFocus: "Give one realistic action the person can take next time.",
      prompt: "Which next step is most helpful?",
      messages: [
        {
          speaker: "learner",
          text: "That makes sense. What would you like me to do differently?",
        },
      ],
      options: [
        {
          label: "“In future meetings, let people finish before you jump in, and jot down your point if needed.”",
          choiceBubble:
            "In future meetings, let people finish before you jump in, and jot down your point if needed.",
          pathLabel: "Clear next step",
          points: 2,
          feedback:
            "Strong choice. This gives a practical, actionable next step.",
          ending: {
            title: "Outcome: Best-practice feedback",
            text:
              "Sam leaves with clear, respectful, and actionable feedback.\n\nYou described the behaviour, explained the impact, and suggested a next step. This makes improvement much more likely.",
          },
        },
        {
          label: "“Just be better next time.”",
          choiceBubble: "Just be better next time.",
          pathLabel: "Vague close",
          points: 0,
          feedback:
            "The intent is fine, but the action is too vague to guide improvement.",
          ending: {
            title: "Outcome: Good intent, weak follow-through",
            text:
              "The conversation started well, but ended without a clear action.\n\nSpecific next steps help people know what ‘better’ actually means.",
          },
        },
      ],
    },
  };

  const root = document.getElementById(instanceId);

  const scoreEl = root.querySelector("[data-score]");
  const pathEl = root.querySelector("[data-path]");
  const pathEmptyEl = root.querySelector("[data-path-empty]");
  const progressEl = root.querySelector("[data-progress]");
  const stageLabelEl = root.querySelector("[data-stage-label]");
  const coachFocusEl = root.querySelector("[data-coach-focus]");
  const promptEl = root.querySelector("[data-prompt]");
  const threadEl = root.querySelector("[data-thread]");
  const optionsEl = root.querySelector("[data-options]");
  const stepEls = [...root.querySelectorAll("[data-step]")];

  const feedbackWrapEl = root.querySelector("[data-feedback-wrap]");
  const feedbackStrengthEl = root.querySelector("[data-feedback-strength]");
  const feedbackTitleEl = root.querySelector("[data-feedback-title]");
  const feedbackTextEl = root.querySelector("[data-feedback-text]");
  const continueBtn = root.querySelector("[data-continue]");

  const endWrapEl = root.querySelector("[data-end-wrap]");
  const endTitleEl = root.querySelector("[data-end-title]");
  const endTextEl = root.querySelector("[data-end-text]");
  const finalScoreEl = root.querySelector("[data-final-score]");
  const ratingEl = root.querySelector("[data-rating]");

  const restartBtn = root.querySelector("[data-restart]");

  const state = {
    currentNode: "start",
    totalPoints: 0,
    choices: 0,
    path: [],
    transcript: [],
  };

  function getPercent() {
    if (state.choices === 0) return 0;
    return Math.round((state.totalPoints / (state.choices * 2)) * 100);
  }

  function getRating(percent) {
    if (percent >= 85) return "Excellent";
    if (percent >= 65) return "Good";
    if (percent >= 40) return "Mixed";
    return "Needs work";
  }

  function hidePanels() {
    feedbackWrapEl.classList.add("hidden");
    endWrapEl.classList.add("hidden");
  }

  function updateScore() {
    scoreEl.textContent = `${getPercent()}%`;
  }

  function updatePath() {
    pathEl.innerHTML = "";

    if (state.path.length === 0) {
      pathEmptyEl.classList.remove("hidden");
      return;
    }

    pathEmptyEl.classList.add("hidden");

    state.path.forEach((item) => {
      const chip = document.createElement("span");
      chip.className = "rounded-full border px-3 py-1 text-sm";

      if (item.points === 2) {
        chip.classList.add("border-black/20", "bg-black/10", "text-black");
      } else if (item.points === 1) {
        chip.classList.add("border-amber-200", "bg-amber-100", "text-amber-800");
      } else {
        chip.classList.add("border-rose-200", "bg-rose-100", "text-rose-800");
      }

      chip.textContent = item.label;
      pathEl.appendChild(chip);
    });
  }

  function updateStages(currentStage) {
    progressEl.value = currentStage;

    stepEls.forEach((stepEl) => {
      const stepNumber = Number(stepEl.dataset.step);

      stepEl.className =
        "rounded-2xl border border-base-300 bg-base-200 p-3 transition";

      if (stepNumber < currentStage) {
        stepEl.classList.add("border-black/20", "bg-black/10");
      } else if (stepNumber === currentStage) {
        stepEl.classList.add("border-black", "ring-2", "ring-black/20");
      }
    });
  }

  function createAvatar(isManager) {
    const avatar = document.createElement("div");
    avatar.className = "avatar";

    const inner = document.createElement("div");
    inner.className = isManager
      ? "w-10 rounded-full overflow-hidden bg-black text-black-content ring ring-black ring-offset-2 ring-offset-base-100 flex items-center justify-center font-bold"
      : "w-10 rounded-full overflow-hidden bg-black text-black-content ring ring-black ring-offset-2 ring-offset-base-100 flex items-center justify-center font-bold";

    const imageSrc = isManager ? managerAvatar : learnerAvatar;
    const label = isManager ? managerName : learnerName;
    const initials = isManager ? managerInitials : learnerInitials;

    if (imageSrc) {
      const img = document.createElement("img");
      img.src = imageSrc;
      img.alt = label;
      img.className = "h-full w-full object-cover";
      inner.appendChild(img);
    } else {
      const span = document.createElement("span");
      span.textContent = initials;
      inner.appendChild(span);
    }

    avatar.appendChild(inner);
    return avatar;
  }

  function createNarratorBlock(text) {
    const wrap = document.createElement("div");
    wrap.className = "mx-auto max-w-2xl rounded-2xl border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/80 shadow-sm";

    const label = document.createElement("p");
    label.className = "mb-1 text-xs font-semibold uppercase tracking-wide text-base-content/50";
    label.textContent = "Scene";

    const body = document.createElement("p");
    body.className = "leading-6";
    body.textContent = text;

    wrap.appendChild(label);
    wrap.appendChild(body);
    return wrap;
  }

  function createChatMessage(message) {
    if (message.speaker === "narrator") {
      return createNarratorBlock(message.text);
    }

    const isManager = message.speaker === "manager";

    const chat = document.createElement("div");
    chat.className = isManager ? "chat chat-end" : "chat chat-start";

    const imageWrap = document.createElement("div");
    imageWrap.className = "chat-image";
    imageWrap.appendChild(createAvatar(isManager));

    const header = document.createElement("div");
    header.className = "chat-header mb-1 text-sm text-base-content/60";
    header.textContent = isManager ? managerName : learnerName;

    const bubble = document.createElement("div");
    bubble.className = isManager
      ? "chat-bubble chat-bubble-black max-w-[80%]"
      : "chat-bubble max-w-[80%]";
    bubble.textContent = message.text;

    chat.appendChild(imageWrap);
    chat.appendChild(header);
    chat.appendChild(bubble);

    return chat;
  }

  function renderThread() {
    threadEl.innerHTML = "";

    state.transcript.forEach((message) => {
      threadEl.appendChild(createChatMessage(message));
    });

    requestAnimationFrame(() => {
      threadEl.scrollTop = threadEl.scrollHeight;
    });
  }

  function renderOptions(node) {
    optionsEl.innerHTML = "";

    node.options.forEach((option, index) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className =
        "btn h-auto min-h-0 justify-start whitespace-normal rounded-2xl border-base-300 bg-base-100 px-5 py-4 text-left normal-case shadow-sm hover:border-black hover:bg-base-200";

      const row = document.createElement("div");
      row.className = "flex items-start gap-3";

      const badge = document.createElement("span");
      badge.className =
        "mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-base-200 text-sm font-semibold";
      badge.textContent = String.fromCharCode(65 + index);

      const text = document.createElement("span");
      text.className = "leading-6";
      text.textContent = option.label;

      row.appendChild(badge);
      row.appendChild(text);
      button.appendChild(row);

      button.addEventListener("click", () => {
        state.totalPoints += option.points;
        state.choices += 1;
        state.path.push({
          label: option.pathLabel,
          points: option.points,
        });
        state.transcript.push({
          speaker: "manager",
          text: option.choiceBubble,
        });

        updateScore();
        updatePath();
        renderThread();

        optionsEl.innerHTML = "";

        feedbackStrengthEl.textContent =
          option.points === 2
            ? "Strong choice"
            : option.points === 1
            ? "Partly helpful"
            : "Weak choice";

        feedbackStrengthEl.className = "badge badge-outline";

        if (option.points === 2) {
          feedbackStrengthEl.classList.add("border-black", "text-black");
        } else if (option.points === 1) {
          feedbackStrengthEl.classList.add("border-amber-500", "text-amber-700");
        } else {
          feedbackStrengthEl.classList.add("border-rose-500", "text-rose-700");
        }

        feedbackTitleEl.textContent = option.pathLabel;
        feedbackTextEl.textContent = option.feedback;
        feedbackWrapEl.classList.remove("hidden");

        continueBtn.textContent = option.ending ? "View outcome" : "Continue";
        continueBtn.onclick = () => {
          if (option.ending) {
            renderEnding(option.ending);
          } else {
            enterNode(option.next, true);
          }
        };
      });

      optionsEl.appendChild(button);
    });
  }

  function enterNode(nodeKey, appendMessages = false) {
    const node = scenario[nodeKey];
    state.currentNode = nodeKey;

    hidePanels();

    if (appendMessages) {
      state.transcript.push(...node.messages);
    } else {
      state.transcript = [...node.messages];
    }

    updateScore();
    updatePath();
    updateStages(node.stage);

    stageLabelEl.textContent = `Step ${node.stage} of 4 · ${node.stageLabel}`;
    coachFocusEl.textContent = node.coachFocus;
    promptEl.textContent = node.prompt;

    renderThread();
    renderOptions(node);
  }

  function renderEnding(ending) {
    const percent = getPercent();
    hidePanels();
    endWrapEl.classList.remove("hidden");

    const currentStage = scenario[state.currentNode].stage;
    updateStages(currentStage);

    stageLabelEl.textContent = "Scenario complete";
    coachFocusEl.textContent = "Review your path and compare it to the model response.";
    promptEl.textContent = "You can restart and try for a stronger outcome.";

    endTitleEl.textContent = ending.title;
    endTextEl.textContent = ending.text;
    finalScoreEl.textContent = `${percent}%`;
    ratingEl.textContent = getRating(percent);
  }

  function restart() {
    state.currentNode = "start";
    state.totalPoints = 0;
    state.choices = 0;
    state.path = [];
    state.transcript = [];
    enterNode("start", false);
  }

  restartBtn.addEventListener("click", restart);

  restart();
</script>