---
import ProductCard from './ProductCard.astro';
import type { Product } from '../data/products';

interface Props {
	id: string;
	title: string;
	description: string;
	products: Product[];
}

const { id, title, description, products } = Astro.props;
---

<section class="product-section shell" id={id} aria-labelledby={`${id}-title`}>
	<div class="section-heading">
		<div>
			<h2 id={`${id}-title`}>{title}</h2>
		</div>
		<p>{description}</p>
	</div>
	<div class="product-grid">
		{products.map((product) => <ProductCard product={product} />)}
	</div>
</section>
