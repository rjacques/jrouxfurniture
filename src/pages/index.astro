---
import Layout from '../layouts/main.astro';
import Hero from '../components/Hero.astro';
import ProductSection from '../components/ProductSection.astro';
import { products } from '../data/products';

const ranges = [
	{
		id: 'essential',
		title: 'Essential',
		description: 'Clean, simple, minimal pieces for everyday living.',
	},
	{
		id: 'ground',
		title: 'Ground',
		description: 'More substantial pieces with weight and presence.',
	},
	{
		id: 'lift',
		title: 'Lift',
		description: 'Lighter, refined forms with softer proportions.',
	},
] as const;
---

<Layout>
	<Hero />
	<div class="collections">
		{ranges.map((range) => (
			<ProductSection
				id={range.id}
				title={range.title}
				description={range.description}
				products={products.filter((product) => product.range === range.title)}
			/>
		))}
	</div>
</Layout>
