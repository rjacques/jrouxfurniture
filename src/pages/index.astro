  </div>
</div>



 <main class="flex-grow max-w-6xl mx-auto pb-20">

<CourseSteps current="intro" />


	
	<h1 class="text-2xl pb-[70px] text-center font-bold mt-[60px]">Learning outcomes</h1>
	<!--<p class="text-gray-500 pb-[40px]">By the end of this short course, you will be able to:</p>-->







	<div class="grid grid-cols-2 gap-8 pb-18">
	<div class="card bg-base-100 shadow-sm bg-gray-50 border-1 border-gray-400">
  <div class="card-body">
	<div class="text-4xl font-thin opacity-30 tabular-nums">01</div>
    <h2 class="card-title">Explain why effective feedback matters</h2>
  </div>
</div>

<div class="card bg-base-100 shadow-sm bg-gray-50 border-1 border-gray-400">
  <div class="card-body">
		<div class="text-4xl font-thin opacity-30 tabular-nums">02</div>
    <h2 class="card-title">Identify the traits of helpful feedback</h2>
  </div>
</div>
<div class="card bg-base-100 shadow-sm bg-gray-50 border-1 border-gray-400">
  <div class="card-body">
		<div class="text-4xl font-thin opacity-30 tabular-nums">03</div>
    <h2 class="card-title">Use a simple model to structure feedback</h2>
  </div>
</div>
<div class="card bg-base-100 shadow-sm bg-gray-50 border-1 border-gray-400">
  <div class="card-body">
		<div class="text-4xl font-thin opacity-30 tabular-nums">04</div>
    <h2 class="card-title">Avoid common feedback mistakes</h2>
  </div>
</div>

</div>



	
