<Layout title="Hello">
	


<div class="hero min-h-auto bg-gray-200">
  <div class="hero-content text-neutral-content text-center">
    <div class="max-w-lg">
      <h1 class="mb-5 text-9xl font-bold"></h1>
     <div class="size- inline-flex justify-start items-center gap-2.5">
