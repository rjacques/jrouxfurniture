---
import '../styles/global.css';
import Layout from '../layouts/main.astro';
import CourseSteps from '../components/CourseSteps.astro';
import CourseNav from '../components/CourseNav.astro';
---

<Layout title="Summary">

  <div class="hero min-h-auto bg-white">
    <div class="hero-content text-neutral-content text-center">
      <div class="max-w-4xl">
        <h1 class="text-4xl text-black pb-[30px] font-bold mt-14">Summary</h1>

        <p class="text-black mb-5">
          You have reached the end of this short course on giving helpful feedback.
        </p>

        <p class="text-black mb-16">
          The key message is simple: feedback is most useful when it is clear,
          timely, respectful, and focused on behaviour that someone can improve.
        </p>
      </div>
    </div>
  </div>

  <main class="flex-grow max-w-6xl mx-auto mt-[40px] pb-20">

<CourseSteps current="summary" />

    <!-- bold summary block -->
    <div class="mt-[70px] rounded-xl bg-black text-white p-10 md:p-14">
      <p class="text-sm uppercase tracking-[0.25em] opacity-70 mb-6">Final takeaway</p>
      <h2 class="text-3xl md:text-5xl font-bold leading-tight max-w-4xl">
        Great feedback is not about saying more.
        <span class="block mt-2 text-gray-300">
          It is about saying the right thing clearly, respectfully, and at the right time.
        </span>
      </h2>
    </div>

    <!-- unique layout -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-[70px]">
      <!-- left side -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-center lg:text-left mb-8">What to remember</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card bg-gray-50 w-full shadow-sm border-1 border-gray-400">
            <div class="card-body">
              <div class="text-4xl font-thin opacity-30 tabular-nums">01</div>
              <h3 class="card-title">Be clear</h3>
              <p>
                Helpful feedback describes what happened in a specific and
                observable way. It avoids vague comments and gives the other
                person something concrete to understand.
              </p>
            </div>
          </div>

          <div class="card bg-gray-50 w-full shadow-sm border-1 border-gray-400">
            <div class="card-body">
              <div class="text-4xl font-thin opacity-30 tabular-nums">02</div>
              <h3 class="card-title">Be timely</h3>
              <p>
                Feedback is more useful when it is given close enough to the
                situation that the details are still fresh and easier to act on.
              </p>
            </div>
          </div>

          <div class="card bg-gray-50 w-full shadow-sm border-1 border-gray-400">
            <div class="card-body">
              <div class="text-4xl font-thin opacity-30 tabular-nums">03</div>
              <h3 class="card-title">Be respectful</h3>
              <p>
                A respectful tone keeps feedback constructive. It makes it more
                likely that the person will listen, reflect, and respond well.
              </p>
            </div>
          </div>

          <div class="card bg-gray-50 w-full shadow-sm border-1 border-gray-400">
            <div class="card-body">
              <div class="text-4xl font-thin opacity-30 tabular-nums">04</div>
              <h3 class="card-title">Focus on behaviour</h3>
              <p>
                Behaviour can be changed. Personality labels usually feel
                personal and unhelpful. Good feedback stays focused on actions.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- right side -->
      <div class="lg:col-span-1">
        <div class="card bg-white w-full shadow-sm border-1 border-gray-400 h-full">
          <div class="card-body">
            <h2 class="card-title text-2xl mb-3">Before you give feedback</h2>
            <p class="mb-5">
              Pause and ask yourself these four questions.
            </p>

            <div class="space-y-4">
              <div class="rounded-lg border border-gray-300 p-4 bg-gray-50">
                <p class="font-bold italic">Am I clear about the behaviour?</p>
              </div>

              <div class="rounded-lg border border-gray-300 p-4 bg-gray-50">
                <p class="font-bold italic">Am I giving this feedback at the right time?</p>
              </div>

              <div class="rounded-lg border border-gray-300 p-4 bg-gray-50">
                <p class="font-bold italic">Am I speaking respectfully?</p>
              </div>

              <div class="rounded-lg border border-gray-300 p-4 bg-gray-50">
                <p class="font-bold italic">Will this help the person know what to do next?</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- reflection / ending -->
    <div
      class="mt-[70px] rounded-xl hero min-h-auto"
      style="background-image: url(https://img.daisyui.com/images/stock/photo-1507358522600-9f71e620c44e.webp);"
    >
      <div class="hero-overlay rounded-xl"></div>
      <div class="hero-content text-neutral-content text-center">
        <div class="max-w-2xl">
          <h2 class="mb-5 mt-8 text-3xl font-bold text-white italic">Reflection</h2>
          <p class="mb-8 text-white">
            Think about one real conversation in your work where you could apply
            this approach. What would you say differently to make your feedback
            clearer, more respectful, and more useful?
          </p>
        </div>
      </div>
    </div>
<CourseNav
  prevHref="/scenario"
  prevLabel="Scenario"
  nextHref="/"
  nextLabel="Back to intro"
/>
  </main>
</Layout>